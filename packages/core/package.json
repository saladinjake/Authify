{
    "name": "@authify/core",
    "version": "0.0.1",
    "description": "Core logic for Authify SDK",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./styles.css": "./dist/styles.css"
    },
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts && copy src\\styles.css dist\\styles.css",
        "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
        "test": "vitest run"
    },
    "keywords": [
        "auth",
        "authentication",
        "sdk",
        "core"
    ],
    "author": "Authify",
    "license": "MIT",
    "devDependencies": {
        "tsup": "^8.0.1",
        "typescript": "^5.4.5"
    }
}