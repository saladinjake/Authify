{
    "name": "@authify/react",
    "version": "0.0.1",
    "description": "React components and hooks for Authify",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --external react",
        "dev": "tsup src/index.ts --format cjs,esm --dts --watch --external react"
    },
    "peerDependencies": {
        "react": ">=16.8.0",
        "react-dom": ">=16.8.0"
    },
    "dependencies": {
        "@authify/core": "../core"
    },
    "devDependencies": {
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "tsup": "^8.0.1",
        "typescript": "^5.3.3"
    }
}